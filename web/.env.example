# Flaim Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ===========================================
# Public Demo Refresh
# ===========================================
# Optional Gemini CLI overrides for the manual refresh runner
PUBLIC_DEMO_GEMINI_MODEL=
PUBLIC_DEMO_GEMINI_BIN=gemini

# ===========================================
# Clerk Authentication (Required)
# ===========================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Optional Clerk URL configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/leagues

# ===========================================
# Worker URLs (Local Development)
# ===========================================
# These point to local wrangler dev servers
# Run 'npm run dev' from the project root to start all services
AUTH_WORKER_URL=http://localhost:8786
NEXT_PUBLIC_AUTH_WORKER_URL=http://localhost:8786
NEXT_PUBLIC_FANTASY_MCP_URL=http://localhost:8790

# ===========================================
# Supabase Configuration (Local Backend)
# ===========================================
# Required for workers/auth-worker during local development
# Create a new Supabase project at https://supabase.com
SUPABASE_URL=https://your-project-ref.supabase.co

# IMPORTANT: For new projects (post-May 2025), use your "Secret Key" (starts with sb_secret_)
# This replaces the legacy SERVICE_ROLE_KEY but serves the same purpose (admin access).
# DO NOT use the "anon" key here.
SUPABASE_SERVICE_KEY=sb_secret_...

# ===========================================
# Product Email (Resend)
# ===========================================
# RESEND_API_KEY is send-only and server-only. Keep direct product email sending
# disabled until a specific transactional trigger has been reviewed and tested.
RESEND_API_KEY=re_...
FLAIM_EMAILS_ENABLED=false
# Optional maintenance sync for Clerk user.updated -> Resend contact repair.
# Signup contact creation/enrichment runs inside the Resend welcome automation.
RESEND_CONTACT_SYNC_ENABLED=false
# Resend Contacts/Segments key used by maintenance sync, backfill, and
# welcome automation setup.
RESEND_CONTACTS_API_KEY=
# Optional: separate key for Resend event and automation APIs. Falls back to
# RESEND_CONTACTS_API_KEY when unset.
RESEND_EVENTS_API_KEY=
# Webhook gate for emitting the welcome automation event. The automation must
# also be enabled in Resend before a welcome email is delivered.
RESEND_WELCOME_AUTOMATION_ENABLED=false
# Resend Segment receiving product contacts. Required by
# scripts/setup-resend-welcome-automation.mjs.
RESEND_CONTACT_SEGMENT_ID=
